# backend/.env.example
# ─────────────────────────────────────────────────────────────────
# Copy this to backend/.env and fill in a real value — backend/.env is
# gitignored, so it never leaves your machine. For production (Render),
# set the same variable in the dashboard instead: Service → Environment.
# ─────────────────────────────────────────────────────────────────

# AI Assistant — free-tier Groq API key (Llama 3.3 70B).
# Get one at console.groq.com → API Keys → Create API Key.
# The chat endpoint degrades gracefully with this unset — /chat will
# just return an error message instead of crashing the whole server.
GROQ_API_KEY=

# Live prediction track record — SERVICE ROLE key (Settings → API →
# service_role secret), NOT the anon/publishable key. Bypasses Row Level
# Security entirely, so it's the one credential in this project that must
# never reach the frontend or a committed file.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the daily GitHub Actions job sends to prove it's allowed
# to trigger POST /admin/run-daily-predictions. Generate any random
# string, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_JOB_SECRET=
