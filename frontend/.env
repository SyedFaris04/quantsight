# frontend/.env
# ─────────────────────────────────────────────────────────────────
# Local development — uses the Vite proxy defined in vite.config.js
# which forwards /api/* → http://localhost:8000/*
VITE_API_URL=http://127.0.0.1:8000

# Supabase — Auth (Google/GitHub/email login) + Postgres (Portfolio and
# Game per-account storage). From a Supabase project's Settings → API page.
# Login/signup and guest-mode localStorage both still work with these unset
# or wrong — you'll just see a console warning and stay in guest mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────
# For production (Vercel), set these in the Vercel dashboard instead:
#   Project Settings → Environment Variables
#   VITE_API_URL          = https://your-app-name.onrender.com
#   VITE_SUPABASE_URL      = https://<project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY = <anon/public key from Supabase Settings → API>
# ─────────────────────────────────────────────────────────────────
